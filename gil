#!/usr/bin/env bash
# gil — v3 실행 진입점. 긴 경로 없이 `gil <cmd>`.
# 진실원은 커밋 그래프. 이 래퍼는 gil을 부르는 얇은 층이다.
#
# 일상 사용은 Go 단일 바이너리 — git만 있으면 다른 의존성 없이 돈다(상현님). Go 이식이
# example 17테스트 + 실제 레포 출력으로 참조(Python)와 동치 검증됨(gil-v3-unified 이 세션).
# Go 바이너리가 없으면(빌드 안 됨) 참조 구현(Python gil.py)으로 폴백 — web은 아직 Python.
here="$(dirname "$0")"
gobin="$here/project/gil-v3-redesign/go/gil"
if [ -x "$gobin" ]; then
  exec "$gobin" "$@"
fi
# 폴백: Go 바이너리 없음 → 참조 구현. (빌드: cd project/gil-v3-redesign/go && go build -o gil .)
exec python3 "$here/project/gil-v3-redesign/source/gil.py" "$@"
